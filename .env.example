# Variaveis lidas pelo docker-compose.yml para o servico postgres
# Copie este arquivo para .env e ajuste os valores antes de subir a infra:
#   cp .env.example .env
#
# ATENCAO: nunca comite o arquivo .env com senhas reais no repositorio.

DB_NAME=cursos_db
DB_USER=cursos_user
DB_PASSWORD=cursos_pass

# Segredo do JWT. Em producao, gere um valor aleatorio longo e mantenha em segredo.
# Ex (Linux/Mac): openssl rand -hex 32
JWT_SECRET=defina-um-segredo-aleatorio-longo-aqui
JWT_EXPIRES_IN=1d

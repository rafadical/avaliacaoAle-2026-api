# Variaveis lidas pelo docker-compose.yml para o servico postgres
# Copie este arquivo para .env e ajuste os valores antes de subir a infra:
#   cp .env.example .env
#
# ATENCAO: nunca comite o arquivo .env com senhas reais no repositorio.

DB_NAME=cursos_db
DB_USER=cursos_user
DB_PASSWORD=cursos_pass
